# Bright Data API Key
# 👉 请在下方填写你的 Bright Data API Key
# 获取方式：登录 Bright Data 控制台 -> Web Scraper API -> 生成 API Token
BRIGHTDATA_API_KEY=YOUR_BRIGHTDATA_API_KEY

# Bright Data API 基础 URL
#BRIGHTDATA_API_URL=https://api.brightdata.com/datasets
BRIGHTDATA_API_URL=https://api.brightdata.com/datasets/v3/scrape


# Instagram 数据集 ID（在 Bright Data 控制台获取）
INSTAGRAM_DATASET_ID=YOUR_INSTAGRAM_DATASET_ID

# TikTok 数据集 ID（在 Bright Data 控制台获取）
TIKTOK_DATASET_ID=YOUR_TIKTOK_DATASET_ID

# 可选：代理池位置（如果使用 Bright Data 代理服务）
PROXY_COUNTRY=US